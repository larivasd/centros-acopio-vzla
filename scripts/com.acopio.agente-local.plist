<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Lanzador del agente local de centros de acopio.
  Instalar:
    cp scripts/com.acopio.agente-local.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.acopio.agente-local.plist
  Quitar:
    launchctl bootout gui/$(id -u)/com.acopio.agente-local
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.acopio.agente-local</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/lucasrivas/Downloads/centros-acopio-vzla/scripts/run-local.sh</string>
  </array>

  <!-- 3 veces al día: 8:00, 12:00 y 18:00. No corre de noche.
       Si la Mac está dormida a esa hora, corre al despertar. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <key>ProcessType</key>
  <string>Background</string>

  <key>StandardOutPath</key>
  <string>/Users/lucasrivas/Downloads/centros-acopio-vzla/scripts/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/lucasrivas/Downloads/centros-acopio-vzla/scripts/launchd.err.log</string>
</dict>
</plist>
